# =============================================================================
# Telegram (gerado em https://my.telegram.org -> App configuration)
# =============================================================================
API_ID=
API_HASH=

# Telefone (so usado em login local interativo - deixa vazio em prod)
TELEGRAM_PHONE=

# String session (preencha em PROD - rode scripts/export_session.py local)
# Em local, deixa vazio que o Telethon cria/le o arquivo .session
STRING_SESSION=

# Nome do arquivo .session local (so usado se STRING_SESSION vazia)
SESSION_NAME=arena_listener

# =============================================================================
# Canal alvo (id numerico, username sem @, ou link t.me/...)
# =============================================================================
TARGET_CHANNEL=

# =============================================================================
# Google Sheets
# =============================================================================
SHEET_ID=1q1NZsXFybFNoR3I5RgS5mllHvHe3eznvzcS3lC5JD7g
SHEET_TAB_LINKS=Links Não Trackeados
SHEET_TAB_REPO=Repo de Links

# Em LOCAL: caminho pro credentials.json
GOOGLE_CREDS_PATH=./credentials.json

# Em PROD (Railway): cola o conteudo INTEIRO do JSON aqui (entre aspas).
# Se preenchido, ignora GOOGLE_CREDS_PATH.
GOOGLE_CREDS_JSON=
